{
  "name": "root",
  "private": true,
  "license": "MIT",
  "scripts": {
    "lint": "nx workspace-lint && nx lint",
    "format": "nx format:write",
    "update": "nx migrate latest",
    "semantic-release": "semantic-release",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^11.0.0",
    "@commitlint/config-conventional": "^11.0.0",
    "@nx/devkit": "18.3.2",
    "@nx/eslint": "^18.3.2",
    "@nx/eslint-plugin": "18.3.2",
    "@nx/js": "18.3.2",
    "@nx/node": "18.3.2",
    "@nx/plugin": "18.3.2",
    "@nx/vite": "^18.3.2",
    "@nx/web": "18.3.2",
    "@nx/workspace": "18.3.2",
    "@octokit/core": "^3.2.1",
    "@semantic-release/changelog": "^5.0.1",
    "@semantic-release/commit-analyzer": "^8.0.1",
    "@semantic-release/git": "^9.0.0",
    "@semantic-release/github": "^7.1.1",
    "@semantic-release/release-notes-generator": "^9.0.1",
    "@swc-node/register": "~1.8.0",
    "@swc/cli": "~0.1.62",
    "@swc/core": "~1.3.85",
    "@swc/helpers": "~0.5.2",
    "@tsconfig/node20": "^20.1.4",
    "@types/cross-spawn": "^6.0.2",
    "@types/jest": "^29.4.0",
    "@types/node": "18.16.9",
    "@types/nodegit": "^0.27.3",
    "@typescript-eslint/eslint-plugin": "~7.7.0",
    "@typescript-eslint/parser": "~7.7.0",
    "@vitest/coverage-v8": "^1.0.4",
    "@vitest/ui": "^1.3.1",
    "conventional-changelog-conventionalcommits": "^4.5.0",
    "cross-spawn": "^7.0.3",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "9.1.0",
    "husky": "^9.0.11",
    "nx": "18.3.2",
    "prettier": "^2.6.2",
    "rimraf": "^5.0.5",
    "semantic-release": "^17.4.4",
    "tslib": "^2.3.0",
    "typescript": "~5.4.2",
    "vite": "~5.0.0",
    "vitest": "^1.5.0"
  },
  "peerDependencies": {
    "@octokit/core": "^3.2.1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/trumbitta/nx-trumbitta.git"
  },
  "publishConfig": {
    "access": "restricted"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "release": {
    "branches": [
      "main"
    ],
    "npmPublish": false,
    "pkgRoot": "dist/$npm_package_name",
    "verifyConditions": [
      "@semantic-release/changelog",
      "@semantic-release/git",
      "@semantic-release/github"
    ],
    "prepare": [
      {
        "path": "@semantic-release/changelog",
        "changelogFile": "CHANGELOG.md"
      },
      {
        "path": "@semantic-release/git",
        "message": "chore(release): ${nextRelease.version}\n\n${nextRelease.notes}"
      }
    ],
    "analyzeCommits": [
      {
        "path": "@semantic-release/commit-analyzer",
        "preset": "conventionalcommits"
      }
    ],
    "generateNotes": [
      {
        "path": "@semantic-release/release-notes-generator",
        "preset": "conventionalcommits"
      }
    ],
    "publish": [
      "@semantic-release/github"
    ],
    "success": false,
    "fail": false
  },
  "packageManager": "pnpm@9.0.4+sha256.caa915eaae9d9aefccf50ee8aeda25a2f8684d8f9d5c6e367eaf176d97c1f89e"
}
